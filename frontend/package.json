{
  "name": "fapiao-tool",
  "private": true,
  "version": "1.0.3",
  "main": "main.cjs",
  "author": "Fapiao Tool",
  "description": "发票合并打印工具",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173",
    "check:release-inputs": "node scripts/check-release-inputs.cjs",
    "pack": "npm run check:release-inputs && vite build && electron-builder --dir",
    "dist": "npm run check:release-inputs && vite build && electron-builder",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.1"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/js": "9.18.0",
    "@playwright/test": "1.50.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "4.0.18",
    "concurrently": "8.2.2",
    "electron": "28.3.3",
    "electron-builder": "24.13.3",
    "eslint": "9.18.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "15.14.0",
    "jsdom": "28.1.0",
    "terser": "5.46.0",
    "typescript": "5.6.3",
    "typescript-eslint": "8.21.0",
    "vite": "5.4.11",
    "vitest": "4.0.18",
    "wait-on": "7.2.0"
  },
  "build": {
    "appId": "com.fapiao.tool",
    "productName": "发票管家",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "main/**/*",
      "preload.cjs",
      "splash.html"
    ],
    "extraResources": [
      {
        "from": "../docs/legal/NOTICE.md",
        "to": "legal/NOTICE.md"
      },
      {
        "from": "../docs/legal/PRIVACY.md",
        "to": "legal/PRIVACY.md"
      },
      {
        "from": "../docs/legal/USER_AGREEMENT.md",
        "to": "legal/USER_AGREEMENT.md"
      },
      {
        "from": "../docs/legal/THIRD_PARTY_NOTICES.md",
        "to": "legal/THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "../python-backend/dist/service",
        "to": "python-backend/service",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../java/target",
        "to": "java",
        "filter": [
          "ofdrw-cli-*.jar",
          "pdf-printer-*.jar"
        ]
      },
      {
        "from": "../jre-min",
        "to": "jre",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "发票管家",
      "include": "build/installer.nsh"
    }
  }
}
